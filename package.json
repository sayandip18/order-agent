{
  "name": "order-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run start:dev --workspace=apps/api\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "web": "npm run dev --workspace=apps/web",
    "api": "npm run start:dev --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
